# CREATE YOUR OWN .env.local FILE FROM .env.example
# AND ADD YOUR OWN KEYS BELOW

# STRIPE_SECRET_KEY=sk_live_or_restricted_live_key_here
# STRIPE_WEBHOOK_SECRET=whsec_live_webhook_secret_here
# Bible Study teen registration uses STRIPE_SECRET_KEY to create the $50 Stripe Checkout payment.

# PRINTFUL_API_KEY=your_printful_api_key_here
# NEXT_PUBLIC_BASE_URL=https://your-production-domain.com
# PRINTFUL_STORE_ID=your_printful_store_id_here


# DABIBLE_GMAIL_ADDRESS=your_sender_email@example.com
# DABIBLE_GMAIL_PASSWORD=your_app_password_here
# DABIBLE_ADMIN_EMAIL=your_admin_email@example.com

# Optional CRM sync for Antioch Bible Study registrations.
# The CRM should expose this endpoint on api.dabible.com and validate the bearer token.
# DABIBLE_CRM_REGISTRATION_ENDPOINT=https://api.dabible.com/api/v3/antioch/bible-study-registrations
# DABIBLE_CRM_API_TOKEN=your_server_to_server_crm_token
# DABIBLE_CRM_TIMEOUT_MS=8000

# reCAPTCHA v2 checkbox site key.
# In local development, the app falls back to Google's public test key if this is not set.
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
